{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "isolatedModules": true,
    "noEmit": true,
    // ✅ REQUIRED (for paths to work)
    "baseUrl": ".",
    // ✅ alias
    "paths": {
      "@/*": ["src/*"]
    },
    // ✅ silence deprecation warning (temporary)
    "ignoreDeprecations": "6.0"
  },
  "include": ["src"]
}
